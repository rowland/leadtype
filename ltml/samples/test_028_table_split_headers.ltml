<ltml units="in" margin="0.5">
  <define id="footer" tag="p" border="dotted" padding="4pt" align="bottom" />
  <define id="header" tag="p" border="dashed" padding="4pt" align="top" font.size="20" font.weight="Bold" />
  <page layout="vbox" grid="0.25in">
    <rules>
      rect { height: 3.8in; }
    </rules>

    <header display="always">Table split with headers</header>
    <p display="always" align="top" border="dotted" padding="4pt">
      The page uses an ordinary vbox layout. The table below is a direct page child, so it can split by whole rows.
    </p>

    <footer display="odd">Odd table footer</footer>
    <footer display="even">Even table footer</footer>

    <table order="rows" cols="2" width="100%" split="true" header-rows="1" border="dotted" padding="6pt">
      <p colspan="2" border="solid" fill="LightYellow" padding="4pt" font.weight="Bold">
        Line items
      </p>

      <rect fill="LightSkyBlue" border="thin" />
      <rect fill="PaleGreen" border="thin" />
      <rect fill="LightSalmon" border="thin" />
      <rect fill="Khaki" border="thin" />
      <rect fill="Plum" border="thin" />
      <rect fill="LightCyan" border="thin" />
    </table>
  </page>
</ltml>

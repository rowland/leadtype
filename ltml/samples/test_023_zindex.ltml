<ltml>
  <page units="in" layout="absolute" grid="0.25in">
    <label font.size="20" font.weight="Bold" left="0.75" top="0.6">z_index</label>

    <p left="0.75" top="1.1" width="2.9">Lower z_index values paint first, so higher values appear on top.</p>
    <rect left="1.0" top="1.95" width="1.6" height="1.0" fill="Gold" border="thin" z_index="-1" />
    <rect left="1.35" top="2.2" width="1.6" height="1.0" fill="PaleGreen" border="thin" />
    <rect left="1.7" top="2.45" width="1.6" height="1.0" fill="LightCoral" border="thin" z_index="1" />

    <p left="4.15" top="1.1" width="2.5">z_index is local to sibling widgets in the same container. The red box is outside the dashed container.</p>
    <div left="4.15" top="1.85" width="2.7" height="2.2" border="dashed">
      <rect left="0.55" top="0.5" width="1.25" height="0.85" fill="Gold" border="thin" z_index="-1" />
      <rect left="0.8" top="0.75" width="1.25" height="0.85" fill="SkyBlue" border="thin" />
      <rect left="1.05" top="1.0" width="1.25" height="0.85" fill="MediumSeaGreen" border="thin" z_index="1" />
    </div>
    <rect left="6.15" top="3.1" width="1.2" height="0.85" fill="LightCoral" border="thin" />
    <label left="4.75" top="4.2">Outside sibling paints after the whole container.</label>
  </page>
</ltml>

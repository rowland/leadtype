<ltml units="in" margin="0.5">
  <define id="header" tag="p" border="dashed" padding="4pt" align="top" font.size="20" font.weight="Bold" />
  <define id="footer" tag="p" border="dotted" padding="4pt" align="bottom" />
  <page units="in" margin="0.5" layout="vbox" overflow="true" grid="0.25in">
    <header display="always">
      Invoice table split
    </header>
    <p display="always" align="top" border="dotted" padding="4pt">
      Table header and footer rows repeat on every fragment page while the outer page footer still follows odd/even rules.
    </p>

    <footer display="odd">Odd invoice footer</footer>
    <footer display="even">Even invoice footer</footer>

    <table order="rows" cols="2" width="100%" split="true" header-rows="1" footer-rows="1" border="dotted" padding="6pt">
      <p colspan="2" border="solid" fill="LightYellow" padding="4pt" font.weight="Bold">
        Description / Amount
      </p>

      <rect height="2.6" fill="LightSkyBlue" border="thin" />
      <rect height="2.6" fill="PaleGreen" border="thin" />
      <rect height="2.6" fill="LightSalmon" border="thin" />
      <rect height="2.6" fill="Khaki" border="thin" />
      <rect height="2.6" fill="Plum" border="thin" />
      <rect height="2.6" fill="LightCyan" border="thin" />
      <rect height="2.6" fill="MistyRose" border="thin" />
      <rect height="2.6" fill="Lavender" border="thin" />

      <p colspan="2" border="solid" fill="Gold" padding="6pt" font.weight="Bold" font.size="14">
        Repeated footer row: Carry forward subtotal
      </p>
    </table>
  </page>
</ltml>

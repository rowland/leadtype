<ltml>
  <page units="in" layout="absolute" grid="0.25in">
    <label font.size="20" font.weight="Bold" left="0.75" top="0.6">Positioning</label>

    <label left="0.75" top="1.1">Absolute widgets use page coordinates.</label>
    <label left="0.75" top="1.45">Dotted box: left="0.75" top="1.45"</label>
    <rect left="0.75" top="1.75" width="3.1" height="2.0" border="dotted" />
    <label left="1.0" top="1.85" border="thin" padding="3pt">Label widget: left="1.0" top="1.85"</label>
    <rect left="1.0" top="2.55" width="1.25" height="0.7" fill="LightBlue" border="thin" />
    <label left="1.0" top="3.35">Blue box: left="1.0" top="2.55"</label>

    <div left="4.25" top="1.45" width="3.0" height="2.4" border="dashed" layout="relative">
      <p left="0.2" top="0.2" width="2">Relative widgets use container coordinates.</p>
      <rect left="0.3" top="0.75" width="1.2" height="0.7" fill="Gold" border="thin" />
      <label left="0.45" top="0.95">0.3, 0.75</label>
      <rect right="-0.3" bottom="-0.3" width="1.0" height="0.6" fill="LightCoral" border="thin" />
      <label right="-0.15" bottom="-0.1">-0.3, -0.3</label>
    </div>

    <div left="0.75" top="4.2" width="6.5" height="2.2" border="dotted">
      <label>Default vbox flow with an auto-positioned child.</label>
      <br/>
      <p width="3.8">The green box sets left/top without an explicit position, so it follows relative positioning inside an ordinary container.</p>
      <rect left="4.8" top="0.85" width="1.2" height="0.8" fill="PaleGreen" border="thin" />
    </div>
  </page>
</ltml>

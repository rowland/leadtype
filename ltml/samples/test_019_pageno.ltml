<ltml margin="0.75in">
  <layout id="vbox" padding="10pt" />
  <define id="h" tag="label" font.weight="Bold" />
  <page>
    <h>Page numbering</h>
    <p>Page <pageno /></p>
  </page>
  <page>
    <h>Page numbering</h>
    <p>Page <pageno /></p>
  </page>
  <page>
    <h>Reset after this page</h>
    <p>This page hides the next-page reset.<pageno hidden="true" reset="1" /></p>
  </page>
  <page>
    <h>Body starts</h>
    <p>Page <pageno font.weight="Bold" /></p>
  </page>
  <page>
    <h>Explicit start</h>
    <p>Page <pageno start="10" /></p>
    <label>This is page <pageno font.weight="Bold" />.</label>
  </page>
  <page>
    <h>Continuation</h>
    <p>Page <pageno /></p>
  </page>
</ltml>

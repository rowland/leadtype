<ltml>
  <pen id="blue_dash" color="blue" width="4pt" pattern="dashed" />
  <layout id="vbox" padding="14" />
  <rules>
    rect { width: 100%; height: 2; }
  </rules>
  <page units="in" margin="1" layout="vbox">
    <rect border="blue_dash" fill="LightYellow" corners="0.5" />
    <rect border="red" corners="0.25" />
    <rect width="3" height="3" border="green" corners="1.5" />
  </page>
</ltml>
